{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(mvn *)",
      "Bash(./mvnw *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(rm -rf *)"
    ]
  }
}
