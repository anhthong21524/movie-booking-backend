# Copy this file to .env and fill in values for local development.
# .env is git-ignored and must never be committed.

# Database
DB_URL=jdbc:postgresql://localhost:5432/movie_booking
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT
JWT_ISSUER=movie-booking-api
JWT_ACCESS_EXPIRY=900        # seconds (15 min)
JWT_REFRESH_EXPIRY=604800    # seconds (7 days)
